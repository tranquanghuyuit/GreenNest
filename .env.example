# Biến môi trường mẫu cho local development.
# Copy thành .env khi chạy local và không commit file .env thật.

NODE_ENV=development
APP_ENV=dev

JWT_SECRET=change-me
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=devsecops_shop
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Google OAuth cho Auth Service khi chạy Docker Compose.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5174/auth/google/callback

# VietQR cho Payment Service.
VIETQR_BANK_ID=your-bank-code
VIETQR_ACCOUNT_NO=your-bank-account-number
VIETQR_ACCOUNT_NAME=GREENNEST MARKET
VIETQR_TEMPLATE=compact2
VIETQR_TRANSFER_PREFIX=GN
